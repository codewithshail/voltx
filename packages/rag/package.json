{
  "name": "@voltx/rag",
  "version": "0.4.7",
  "description": "VoltX RAG pipeline primitives — document loading, chunking, embedding, retrieval",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@voltx/ai": "workspace:^",
    "@voltx/db": "workspace:^"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codewithshail/voltx.git",
    "directory": "packages/rag"
  },
  "homepage": "https://voltx.co.in",
  "bugs": "https://github.com/codewithshail/voltx/issues",
  "keywords": [
    "voltx",
    "rag",
    "retrieval-augmented-generation",
    "embeddings",
    "chunking",
    "pipeline",
    "document-loaders",
    "text-splitters",
    "vector-search"
  ]
}
